# Frontend (Vite) — copy to .env.local
# Leave empty to use same-origin (/api/...) and rely on Vite proxy in dev + Vercel routes in prod.
# Examples:
# - local: (empty) + Vite proxy in `vite.config.js`
# - custom API: VITE_API_URL=https://example.com
VITE_API_URL=

# Backend — copy to backend/.env
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/polska2038
SECRET_KEY=your-super-secret-jwt-key-change-this
ALLOWED_ORIGINS=http://localhost:5173,https://polska2038.vercel.app
ACCESS_TOKEN_EXPIRE_MINUTES=480

# SMTP (Manifesto Delivery System) — set in Vercel Environment Variables
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=apikey_or_username
SMTP_PASS=your-smtp-password
# Optional: if empty, defaults to SMTP_USER
SMTP_FROM="Polska2038 <no-reply@polska2038.pl>"
# true = STARTTLS (recommended for port 587); false = SMTP_SSL (often port 465)
SMTP_TLS=true
